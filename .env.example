# Copy this file to server/.env and client/.env and fill in your values.
# Never commit .env files.

# === server/.env ===
PORT=3001
NODE_ENV=development
DB_PATH=./data/stockdashboard.db

# Finnhub (https://finnhub.io - free account, 60 req/min)
FINNHUB_API_KEY=your_finnhub_api_key_here

# FCS API (https://fcsapi.com - free: 500 calls/month, covers Thai SET stocks)
FCS_API_KEY=your_fcs_api_key_here

# === client/.env ===
VITE_FINNHUB_API_KEY=your_finnhub_api_key_here
VITE_API_BASE_URL=http://localhost:3001
